@model List<ResultInstructorDto>
@{
    ViewData["Title"] = "Index";
   Layout="~/Areas/Admin/Views/AdminLayout/AdminLayout.cshtml";
}

<h3>Instructor</h3>
@{
    int count=0;
}
<table class="table table-bordered">
    <tr>
        <th>#</th>
        <th>Profile Image</th>
        <th>Name Surname</th>
        <th>Title</th>
        <th>Social 1</th>
        <th>Social 2</th>
        <th>Social 3</th>
        <th>Operations</th>
    </tr>

    @foreach (var item in Model)
    {
        count++;
        <tr>
            <th>@count</th>
            <td><img src="@item.ImageUrl" style="height:75px;width:75px;" /> </td>
            <td>@item.FullName</td>
            <td>@item.Title</td>
            <td>@item.Social1</td>
            <td>@item.Social2</td>
            <td>@item.Social3</td>
            <td>
                <a href="/Admin/Instructor/DeleteInstructor/@item.InstructorId" class="btn btn-danger">Delete</a>
                <a href="/Admin/Instructor/UpdateInstructor/@item.InstructorId" class="btn btn-info">Update</a>
            </td>
        </tr>
    }           
</table>

<a href="/Admin/Instructor/CreateInstructor" class="btn btn-primary">Add new Instructor</a>

