@model List<ResultEventDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/AdminLayout.cshtml";
    int count = 0;
}

<h3>Event</h3>

<table class="table table-bordered">
    <tr>
        <th>#</th>
        <th>Image</th>
        <th>Title</th>
        <th>Description</th>
        <th>Location</th>
        <th>Date</th>
        <th>Start Time</th>
        <th>End Time</th>
        <th>Operations</th>
    </tr>

    @foreach (var item in Model)
    { 
        count++;
        <tr>
            <th>@count</th>
            <td><img src="@item.ImageUrl" style="height:75px;width:75px;" /> </td>
            <td>@item.Title</td>
            <td>@item.Description</td>
            <td>@item.Location</td>
            <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@item.StartTime.ToString(@"hh\:mm")</td>
            <td>@item.EndTime.ToString(@"hh\:mm")</td>
            <td>
                <a href="/Admin/Event/DeleteEvent/@item.EventId" class="btn btn-danger"><i class="fa fa-trash"></i></a>
                <a href="/Admin/Event/UpdateEvent/@item.EventId" class="btn btn-info"><i class="fa fa-pen"></i></a>
            </td>
        </tr>
    }
</table>

<a href="/Admin/Event/CreateEvent" class="btn btn-primary">Add Event</a>




