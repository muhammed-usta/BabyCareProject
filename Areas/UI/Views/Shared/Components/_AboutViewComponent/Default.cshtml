@model List<ResultAboutDto>
@*
    _AboutViewComponent
*@


<div class="container-fluid py-5 about bg-light">
    <div class="container py-5">
        <div class="row g-5 align-items-center">
           
            <div class="col-lg-5 wow fadeIn" data-wow-delay="0.1s">
                <div class="video border">
                    <button type="button" class="btn btn-play" data-bs-toggle="modal" data-src="ViewBag.videoUrl" data-bs-target="#videoModal">
                        <span></span>
                    </button>
                </div>
            </div>
        
            <div class="col-lg-7 wow fadeIn" data-wow-delay="0.3s">
                <h4 class="text-primary mb-4 border-bottom border-primary border-2 d-inline-block p-2 title-border-radius">About Us</h4>

                @foreach (var item in Model)
                {
                    <div class="mb-5">
                        <h1 class="text-dark mb-4 display-5">@item.Title</h1>
                        <p class="text-dark mb-4">@item.Description</p>

                        @if (item.Items != null && item.Items.Length > 0)
                        {
                            <div class="d-flex flex-wrap gap-2 mb-4">
                                @foreach (var activity in item.Items)
                                {
                                    <span class="badge rounded-pill bg-primary px-3 py-2 fs-6">
                                        <i class="bi bi-check-circle me-1"></i> @activity
                                    </span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!-- Modal Video -->
<div class="modal fade" id="videoModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content rounded-0">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Youtube Video</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- 16:9 aspect ratio -->
                <div class="ratio ratio-16x9">
                    <iframe class="embed-responsive-item" src="" id="video" allowfullscreen allowscriptaccess="always"
                            allow="autoplay"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>